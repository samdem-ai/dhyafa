{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["expo/tsconfig.base", "../../tsconfig.base.json"],
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src",
    "app",
    "*.ts",
    "*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts"
  ]
}
