# ─────────────────────────────────────────────────────────────
# Dyafa — environment template. Copy to .env and fill in.
# NEVER commit a real .env. Service-role + Chargily keys are SERVER-ONLY.
# ─────────────────────────────────────────────────────────────

# Supabase (server-side / Edge Functions / scripts)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key   # SERVER ONLY — never ship to a client

# Chargily Pay (SERVER ONLY — used inside Edge Functions, never in app bundles)
CHARGILY_SECRET_KEY=test_sk_xxx
CHARGILY_BASE_URL=https://pay.chargily.net/test/api/v2   # live: https://pay.chargily.net/api/v2
CHARGILY_WEBHOOK_SECRET=test_whsec_xxx

# Next.js apps (admin, hotel) — only NEXT_PUBLIC_* reach the browser
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Expo customer app — only EXPO_PUBLIC_* reach the device bundle
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Maps (customer app) — Mapbox public token
EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx
